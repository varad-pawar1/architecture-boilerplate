NODE_ENV=development
PORT=3000

# MongoDB
DB_URL=mongodb://127.0.0.1:27017/mvc_boilerplate

# Redis (sessions + BullMQ) — same pattern as mock-ai-backend
QUEUE_REDIS_HOST=127.0.0.1
QUEUE_REDIS_PORT=6379
# QUEUE_REDIS_USERNAME=
# QUEUE_REDIS_PASSWORD=

# Session cookie TTL (minutes)
ACCESS_EXPIRATION_MINUTES=1440

# Used for any HMAC-style tokens you add later
CRYPTO_SECRET=change-me-in-development

# Optional: bcrypt fallback in user model (set empty to disable)
# DEFAULT_PASSWORD=

# Local HTTP: set COOKIE_SECURE=false so browsers accept the session cookie
COOKIE_SECURE=false
