NODE_ENV=development
PORT=3000

# MongoDB
DB_URL=mongodb://127.0.0.1:27017/mvc_boilerplate

# Redis (sessions + BullMQ workers run in the same process as the API by default — see src/server.js)
QUEUE_REDIS_HOST=127.0.0.1
QUEUE_REDIS_PORT=6379
# QUEUE_REDIS_USERNAME=
# QUEUE_REDIS_PASSWORD=

ACCESS_EXPIRATION_MINUTES=1440
CRYPTO_SECRET=change-me-in-development
COOKIE_SECURE=false

# Public URL of this API (used in verification links in emails). Behind a proxy, set this explicitly.
PUBLIC_API_URL=http://localhost:3000

# Frontend URL for post-verify redirect (?redirect=1) and "login" link in templates
WEB_APP_URL=http://localhost:4200

APP_NAME=MVC Boilerplate

# Verification token lifetime (minutes)
VERIFY_EMAIL_EXPIRATION_MINUTES=1440

# Email: either configure real SMTP, or in development rely on Ethereal (fake inbox + preview URL in console).
# USE_ETHEREAL=false disables Ethereal; set SMTP_* to use Gmail, SendGrid, etc.
USE_ETHEREAL=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER= varad.pawar@venturepact.com
SMTP_PASS= felc ztvt pvxf lrdx
EMAIL_FROM="MVC Boilerplate <noreply@example.com>"

# Optional: bcrypt fallback in user model
# DEFAULT_PASSWORD=
